{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/foundation/schemas/insight.schema.json",
  "title": "Insight",
  "description": "Canonical OpenDataWorld schema for a governed, evidence-backed insight.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "name",
    "description",
    "statement",
    "basedOn",
    "evidence",
    "confidence",
    "explanation",
    "owner",
    "reviewStatus",
    "lifecycleState",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string" },
    "canonicalId": { "type": "string" },
    "type": { "const": "Insight" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "insightType": {
      "type": "string",
      "enum": [
        "Observation",
        "Trend",
        "Anomaly",
        "Risk",
        "Opportunity",
        "Recommendation",
        "Explanation",
        "Benchmark",
        "Forecast",
        "DecisionSupport",
        "Other"
      ]
    },
    "statement": { "type": "string" },
    "basedOn": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "version": { "type": "string" },
          "role": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "explanation": { "type": "string" },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "recommendedActions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "owner": { "type": "string" },
    "generatedBy": { "type": "string" },
    "aiInvolvement": {
      "type": "string",
      "enum": ["None", "Assisted", "Generated", "Summarized", "Classified", "Enriched", "Reviewed"]
    },
    "trustAssessment": { "type": "string" },
    "provenance": { "type": "string" },
    "lineage": { "type": "string" },
    "reviewStatus": {
      "type": "string",
      "enum": ["NotReviewed", "PendingReview", "Reviewed", "Approved", "Rejected", "Superseded", "Revoked"]
    },
    "reviewedBy": { "type": "string" },
    "lifecycleState": {
      "type": "string",
      "enum": ["Draft", "Proposed", "Active", "Published", "Deprecated", "Superseded", "Archived", "Retired", "Revoked"]
    },
    "version": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "if": { "properties": { "reviewStatus": { "const": "Approved" } } },
      "then": { "required": ["reviewedBy"] }
    },
    {
      "if": { "properties": { "lifecycleState": { "const": "Published" } } },
      "then": { "required": ["provenance", "trustAssessment"] }
    },
    {
      "if": {
        "properties": {
          "aiInvolvement": {
            "enum": ["Assisted", "Generated", "Summarized", "Classified", "Enriched", "Reviewed"]
          }
        }
      },
      "then": { "required": ["generatedBy"] }
    }
  ]
}
