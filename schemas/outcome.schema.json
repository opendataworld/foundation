{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/foundation/schemas/outcome.schema.json",
  "title": "Outcome",
  "description": "Canonical OpenDataWorld schema for an outcome produced by a decision, action, workflow, service, or program.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "name",
    "description",
    "producedBy",
    "measuredAt",
    "lifecycleState",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string" },
    "canonicalId": { "type": "string" },
    "type": { "const": "Outcome" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "producedBy": {
      "type": "string",
      "description": "Reference to the decision, action, workflow, service, or program that produced the outcome."
    },
    "outcomeType": {
      "type": "string",
      "enum": [
        "Operational",
        "Financial",
        "PublicValue",
        "Research",
        "Social",
        "Compliance",
        "RiskReduction",
        "QualityImprovement",
        "DecisionImprovement",
        "TimeSavings",
        "Other"
      ]
    },
    "measuredAt": { "type": "string", "format": "date-time" },
    "metrics": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "baseline": {
      "type": "object",
      "additionalProperties": true
    },
    "actual": {
      "type": "object",
      "additionalProperties": true
    },
    "impact": {
      "type": "string"
    },
    "value": {
      "type": "object",
      "properties": {
        "valueType": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "unit": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "learning": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "improvementActions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "reviewStatus": {
      "type": "string",
      "enum": ["NotReviewed", "PendingReview", "Reviewed", "Approved", "Rejected", "Superseded"]
    },
    "reviewedBy": { "type": "string" },
    "lifecycleState": {
      "type": "string",
      "enum": ["Draft", "Observed", "Measured", "Reviewed", "Accepted", "Rejected", "Archived", "Superseded"]
    },
    "version": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "if": { "properties": { "lifecycleState": { "const": "Accepted" } } },
      "then": { "required": ["reviewedBy", "evidence"] }
    }
  ]
}
