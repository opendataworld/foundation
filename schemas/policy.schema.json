{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/foundation/schemas/policy.schema.json",
  "title": "Policy",
  "description": "Canonical OpenDataWorld schema for a governed policy.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "name",
    "description",
    "policyType",
    "owner",
    "version",
    "lifecycleState",
    "rules",
    "appliesTo",
    "effect",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string" },
    "canonicalId": { "type": "string" },
    "type": { "const": "Policy" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "policyType": {
      "type": "string",
      "enum": [
        "AccessPolicy",
        "PrivacyPolicy",
        "RetentionPolicy",
        "PublicationPolicy",
        "ClassificationPolicy",
        "QualityPolicy",
        "SecurityPolicy",
        "AgentPolicy",
        "AnalyticsPolicy",
        "DecisionPolicy",
        "CompliancePolicy",
        "Other"
      ]
    },
    "owner": { "type": "string" },
    "approver": { "type": "string" },
    "appliesTo": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "condition", "effect"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "condition": { "type": "string" },
          "effect": {
            "type": "string",
            "enum": ["Allow", "Deny", "RequireApproval", "RequireEvidence", "Escalate", "Log", "Notify"]
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error", "critical"]
          },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "effect": {
      "type": "string",
      "enum": ["Allow", "Deny", "RequireApproval", "RequireEvidence", "Escalate", "Mixed"]
    },
    "effectiveFrom": { "type": "string", "format": "date-time" },
    "effectiveTo": { "type": "string", "format": "date-time" },
    "version": { "type": "string" },
    "lifecycleState": {
      "type": "string",
      "enum": ["Draft", "Reviewed", "Approved", "Active", "Superseded", "Deprecated", "Retired", "Revoked", "Archived"]
    },
    "provenance": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycleState": { "const": "Active" }
        }
      },
      "then": {
        "required": ["approver", "effectiveFrom"]
      }
    }
  ]
}
