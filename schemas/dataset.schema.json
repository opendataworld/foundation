{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/foundation/schemas/dataset.schema.json",
  "title": "Dataset",
  "description": "Canonical OpenDataWorld schema for a governed dataset.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "name",
    "description",
    "owner",
    "steward",
    "source",
    "schema",
    "classification",
    "license",
    "accessPolicy",
    "provenance",
    "lifecycleState",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Canonical dataset identifier."
    },
    "canonicalId": {
      "type": "string",
      "description": "Stable identifier across versions, aliases, and systems."
    },
    "type": {
      "const": "Dataset"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "description": "Identity reference for accountable owner."
    },
    "steward": {
      "type": "string",
      "description": "Identity reference for responsible steward."
    },
    "source": {
      "type": "string",
      "description": "DataSource reference."
    },
    "schema": {
      "type": "string",
      "description": "Schema reference."
    },
    "schemaException": {
      "type": "boolean",
      "default": false
    },
    "classification": {
      "type": "object",
      "required": [
        "domain",
        "dataSensitivity",
        "dataAccessLevel",
        "dataQualityTier",
        "dataLifecycleState",
        "dataLicenseClass",
        "dataTrustLevel"
      ],
      "properties": {
        "domain": {
          "type": "string"
        },
        "dataAssetType": {
          "const": "Dataset"
        },
        "dataSensitivity": {
          "type": "string",
          "enum": [
            "Public",
            "Open",
            "Internal",
            "Confidential",
            "Restricted",
            "Secret",
            "PersonalData",
            "SensitivePersonalData",
            "FinancialData",
            "HealthData",
            "GovernmentRestrictedData",
            "ChildData",
            "LocationData",
            "BiometricData",
            "CredentialData",
            "Unknown"
          ]
        },
        "dataAccessLevel": {
          "type": "string",
          "enum": [
            "OpenAccess",
            "PublicReadOnly",
            "RegisteredUserAccess",
            "OrganizationInternal",
            "RoleRestricted",
            "PurposeRestricted",
            "ConsentRequired",
            "ApprovalRequired",
            "ContractRequired",
            "RegulatedAccess",
            "AdminOnly",
            "NoAccess"
          ]
        },
        "dataQualityTier": {
          "type": "string",
          "enum": [
            "Unassessed",
            "Bronze",
            "Silver",
            "Gold",
            "Platinum",
            "Certified"
          ]
        },
        "dataLifecycleState": {
          "type": "string"
        },
        "dataLicenseClass": {
          "type": "string"
        },
        "dataTrustLevel": {
          "type": "string",
          "enum": [
            "Unknown",
            "Low",
            "Medium",
            "High",
            "Verified",
            "Certified",
            "Revoked"
          ]
        },
        "dataCriticality": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "license": {
      "type": "string"
    },
    "accessPolicy": {
      "type": "string"
    },
    "qualityProfile": {
      "type": "string"
    },
    "trustAssessment": {
      "type": "string"
    },
    "provenance": {
      "type": "string"
    },
    "lineage": {
      "type": "string"
    },
    "distributions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["format", "accessURL"],
        "properties": {
          "format": {
            "type": "string"
          },
          "accessURL": {
            "type": "string"
          },
          "mediaType": {
            "type": "string"
          },
          "downloadURL": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "default": []
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Registered",
        "Ingested",
        "Validated",
        "Approved",
        "Active",
        "Published",
        "Deprecated",
        "Superseded",
        "Archived",
        "Retired",
        "Revoked",
        "Deleted"
      ]
    },
    "version": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycleState": {
            "const": "Published"
          }
        }
      },
      "then": {
        "required": [
          "license",
          "accessPolicy",
          "provenance",
          "trustAssessment"
        ],
        "properties": {
          "classification": {
            "properties": {
              "dataSensitivity": {
                "not": {
                  "const": "Unknown"
                }
              }
            }
          }
        }
      }
    }
  ]
}
