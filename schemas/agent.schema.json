{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/foundation/schemas/agent.schema.json",
  "title": "Agent",
  "description": "Canonical OpenDataWorld schema for a governed software agent.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "name",
    "description",
    "owner",
    "operator",
    "purpose",
    "riskLevel",
    "allowedActions",
    "allowedTools",
    "allowedDataClasses",
    "approvalRequirements",
    "policies",
    "lifecycleState",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string" },
    "canonicalId": { "type": "string" },
    "type": { "const": "Agent" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "agentType": {
      "type": "string",
      "enum": [
        "DiscoveryAgent",
        "MetadataAgent",
        "ClassificationAgent",
        "SchemaMappingAgent",
        "QualityAgent",
        "LineageAgent",
        "AnalyticsAgent",
        "InsightAgent",
        "PublishingAgent",
        "GovernanceAgent",
        "DecisionSupportAgent",
        "AuditAgent",
        "Other"
      ]
    },
    "owner": { "type": "string" },
    "operator": { "type": "string" },
    "purpose": { "type": "string" },
    "objectives": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "riskLevel": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Critical"]
    },
    "allowedActions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "allowedTools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["toolId", "permission"],
        "properties": {
          "toolId": { "type": "string" },
          "permission": { "type": "string", "enum": ["Read", "Write", "Execute", "Admin"] },
          "riskLevel": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
          "approvalRequired": { "type": "boolean" }
        },
        "additionalProperties": true
      },
      "default": []
    },
    "allowedDataClasses": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "approvalRequirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "approvalType"],
        "properties": {
          "condition": { "type": "string" },
          "approvalType": { "type": "string" },
          "approverRole": { "type": "string" },
          "required": { "type": "boolean" }
        },
        "additionalProperties": true
      },
      "default": []
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "memoryPolicy": { "type": "string" },
    "contextSources": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "evaluationCadence": { "type": "string" },
        "evaluationMetrics": { "type": "array", "items": { "type": "string" } },
        "lastEvaluatedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "trustAssessment": { "type": "string" },
    "auditRequired": { "type": "boolean", "default": true },
    "provenanceRequired": { "type": "boolean", "default": true },
    "lineageRequiredForTransformations": { "type": "boolean", "default": true },
    "lifecycleState": {
      "type": "string",
      "enum": ["Draft", "Proposed", "Active", "Suspended", "Deprecated", "Retired", "Revoked", "Archived"]
    },
    "version": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "if": { "properties": { "riskLevel": { "enum": ["High", "Critical"] } } },
      "then": { "required": ["trustAssessment", "approvalRequirements"] }
    },
    {
      "if": { "properties": { "lifecycleState": { "const": "Active" } } },
      "then": { "required": ["policies", "allowedActions", "owner", "operator"] }
    }
  ]
}
