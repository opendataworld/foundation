{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/foundation/schemas/metric.schema.json",
  "title": "Metric",
  "description": "Canonical OpenDataWorld schema for a governed metric definition.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "name",
    "description",
    "definition",
    "owner",
    "formula",
    "inputDataAssets",
    "unit",
    "version",
    "lifecycleState",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string" },
    "canonicalId": { "type": "string" },
    "type": { "const": "Metric" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "definition": { "type": "string" },
    "owner": { "type": "string" },
    "steward": { "type": "string" },
    "formula": { "type": "string" },
    "calculationMethod": { "type": "string" },
    "inputDataAssets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "role": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "dimensions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "unit": { "type": "string" },
    "refreshCadence": { "type": "string" },
    "qualityRules": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "classification": {
      "type": "object",
      "additionalProperties": true
    },
    "policyRefs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "provenance": { "type": "string" },
    "lineage": { "type": "string" },
    "trustAssessment": { "type": "string" },
    "reviewStatus": {
      "type": "string",
      "enum": ["NotReviewed", "PendingReview", "Reviewed", "Approved", "Rejected", "Deprecated"]
    },
    "lifecycleState": {
      "type": "string",
      "enum": ["Draft", "Proposed", "Active", "Published", "Deprecated", "Superseded", "Archived", "Retired", "Revoked"]
    },
    "version": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "if": { "properties": { "lifecycleState": { "const": "Published" } } },
      "then": { "required": ["reviewStatus", "provenance"] }
    }
  ]
}
