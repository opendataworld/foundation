{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendataworld.org/foundation/schemas/decision.schema.json",
  "title": "Decision",
  "description": "Canonical OpenDataWorld schema for a data-informed, evidence-backed decision record.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "decisionType",
    "name",
    "description",
    "madeBy",
    "madeAt",
    "selectedOption",
    "rationale",
    "reviewStatus",
    "lifecycleState",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string" },
    "canonicalId": { "type": "string" },
    "type": { "const": "Decision" },
    "decisionType": {
      "type": "string",
      "enum": ["Operational", "Strategic", "Governance", "Access", "Publication", "Analytics", "Risk", "Policy", "Investment", "PublicInterest", "Other"]
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "madeBy": { "type": "string" },
    "madeAt": { "type": "string", "format": "date-time" },
    "basedOnDataAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "accessedAt": { "type": "string", "format": "date-time" },
          "trustAssessment": { "type": "string" }
        },
        "additionalProperties": true
      },
      "default": []
    },
    "basedOnEvidence": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["option"],
        "properties": {
          "option": { "type": "string" },
          "pros": { "type": "array", "items": { "type": "string" } },
          "cons": { "type": "array", "items": { "type": "string" } },
          "risk": { "type": "string" },
          "expectedOutcome": { "type": "string" }
        },
        "additionalProperties": true
      },
      "default": []
    },
    "selectedOption": { "type": "string" },
    "rationale": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "policyRefs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "approvalRefs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "outcome": { "type": "string" },
    "reviewStatus": {
      "type": "string",
      "enum": ["NotReviewed", "PendingReview", "Reviewed", "Approved", "Rejected", "Superseded", "Revoked"]
    },
    "reviewedBy": { "type": "string" },
    "lifecycleState": {
      "type": "string",
      "enum": ["Draft", "Proposed", "Active", "Approved", "Executed", "Superseded", "Archived", "Revoked"]
    },
    "version": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "allOf": [
    {
      "if": { "properties": { "reviewStatus": { "const": "Approved" } } },
      "then": { "required": ["reviewedBy"] }
    },
    {
      "if": { "properties": { "basedOnDataAssets": { "minItems": 1 } } },
      "then": { "required": ["basedOnDataAssets"] }
    }
  ]
}
